{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "forkProcessing": "enabled",
  "labels": ["chore(deps)", "dependencies"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "branchConcurrentLimit": 0,
  "dependencyDashboard": true,
  "commitMessagePrefix": "chore(deps):",
  "schedule": ["after 10am and before 11am"],
  "timezone": "Europe/Amsterdam",
  "ignoreDeps": ["int:CONTENT_PROXY_PORT"],
  "packageRules": [
    {
      "matchManagers": ["gradle", "gradle-wrapper", "gradle-version-catalog"],
      "groupName": "Gradle dependencies",
      "labels": ["chore(deps)", "dependencies"]
    },
    {
      "matchManagers": ["gradle", "gradle-wrapper", "gradle-version-catalog"],
      "matchUpdateTypes": ["major"],
      "groupName": "Major Gradle upgrades",
      "labels": ["chore(deps)", "dependencies", "breaking-change"]
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "labels": ["chore(deps)", "ci"],
      "pinDigests": true
    },
    {
      "matchPackageNames": ["androidx.**", "com.google.accompanist:**"],
      "groupName": "AndroidX & Accompanist",
      "labels": ["chore(deps)", "dependencies"]
    },
    {
      "matchPackageNames": ["org.jetbrains.kotlin:**", "org.jetbrains.kotlinx:**"],
      "groupName": "Kotlin & Coroutines",
      "labels": ["chore(deps)", "dependencies"]
    },
    {
      "matchPackageNames": ["androidx.compose:**"],
      "groupName": "Jetpack Compose",
      "labels": ["chore(deps)", "dependencies"]
    },
    {
      "matchPackageNames": ["com.google.**", "com.googlecode.**"],
      "groupName": "Google libraries",
      "labels": ["chore(deps)", "dependencies"]
    }
  ]
}
